{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "technician-live-cert-manifest.schema.json",
  "title": "Technician Live-Cert Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "manifestVersion", "stages", "repairs", "coreSequence", "fullRunCmd", "bootstrapCmd"],
  "properties": {
    "schema": { "type": "string", "const": "agentswitchboard.technician-live-cert-manifest.v1" },
    "manifestVersion": { "type": "integer", "const": 1 },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stageId", "name", "cmd", "implementation", "requiresElevation", "requiresNetwork", "mutatesWorkstation", "optional", "dependencies", "manualObservationRequired", "evidenceArtifacts"],
        "properties": {
          "stageId": { "type": "string", "pattern": "^P\\d{2}$" },
          "name": { "type": "string", "minLength": 1 },
          "cmd": { "type": "string", "pattern": "^[A-Za-z0-9-]+\\.cmd$" },
          "implementation": { "type": "string", "pattern": "^stages/[A-Za-z0-9-]+\\.ps1$" },
          "requiresElevation": { "type": "boolean" },
          "requiresNetwork": { "type": "boolean" },
          "mutatesWorkstation": { "type": "boolean" },
          "optional": { "type": "boolean" },
          "dependencies": { "type": "array", "items": { "type": "string", "pattern": "^P\\d{2}$" } },
          "manualObservationRequired": { "type": "boolean" },
          "manualObservationPrompt": { "type": "string", "minLength": 1 },
          "evidenceArtifacts": { "type": "array", "items": { "type": "string" } }
        }
      },
      "uniqueItems": true
    },
    "repairs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repairId", "name", "cmd", "implementation", "requiresElevation", "requiresNetwork", "targetsStages"],
        "properties": {
          "repairId": { "type": "string", "pattern": "^[A-Za-z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "cmd": { "type": "string", "pattern": "^[A-Za-z0-9-]+\\.cmd$" },
          "implementation": { "type": "string", "pattern": "^stages/[A-Za-z0-9-]+\\.ps1$" },
          "requiresElevation": { "type": "boolean" },
          "requiresNetwork": { "type": "boolean" },
          "targetsStages": { "type": "array", "items": { "type": "string", "pattern": "^P\\d{2}$" } }
        }
      }
    },
    "coreSequence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^P\\d{2}$" },
      "uniqueItems": true
    },
    "fullRunCmd": { "type": "string", "pattern": "^[A-Za-z0-9-]+\\.cmd$" },
    "bootstrapCmd": { "type": "string", "pattern": "^[A-Za-z0-9-]+\\.cmd$" }
  }
}
