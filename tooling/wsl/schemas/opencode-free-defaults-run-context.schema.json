{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agentswitchboard-opencode-free-defaults-run-context/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "workflowId",
    "startedAt",
    "mode",
    "sourceRepoPath",
    "remoteName",
    "remoteBranch",
    "targetHead",
    "worktreePath",
    "status"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "runId": {"type": "string", "minLength": 8},
    "workflowId": {"const": "opencode-free-defaults-repair"},
    "startedAt": {"type": "string", "format": "date-time"},
    "completedAt": {"type": ["string", "null"], "format": "date-time"},
    "mode": {"enum": ["apply", "plan-only"]},
    "sourceRepoPath": {"type": "string", "minLength": 1},
    "sourceDirty": {"type": "boolean"},
    "remoteName": {"type": "string", "minLength": 1},
    "remoteBranch": {"type": "string", "minLength": 1},
    "requestedValidatedHead": {"type": ["string", "null"]},
    "targetHead": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "worktreePath": {"type": "string", "minLength": 1},
    "distribution": {"type": ["string", "null"]},
    "status": {"enum": ["starting", "planned", "succeeded", "failed"]},
    "error": {"type": ["string", "null"]},
    "proofLevel": {"enum": ["contract", "local-plan", "local-configuration"]},
    "proofCeiling": {"type": "string", "minLength": 1}
  }
}
