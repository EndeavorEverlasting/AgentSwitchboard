{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/AgentSwitchboard/tooling/contracts/worker-run.schema.json",
  "title": "AgentSwitchboard Worker Run Record",
  "description": "Canonical handoff record for one isolated worker branch or worktree.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "runId", "repository", "worker", "git", "scope", "dependencies", "changes", "validation", "evidence", "integration"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "runId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "remote": { "type": ["string", "null"] }
      }
    },
    "worker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executor", "provider", "lane"],
      "properties": {
        "executor": { "type": "string", "minLength": 1 },
        "provider": { "type": ["string", "null"] },
        "lane": { "type": "string", "minLength": 1 }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch", "worktreePath", "baseSha", "headSha", "dirty"],
      "properties": {
        "branch": { "type": "string", "minLength": 1 },
        "worktreePath": { "type": "string", "minLength": 1 },
        "baseSha": { "$ref": "#/$defs/sha" },
        "headSha": { "$ref": "#/$defs/sha" },
        "dirty": { "type": "boolean" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owned", "forbidden"],
      "properties": {
        "owned": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "forbidden": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parentRunIds", "consumedCommits"],
      "properties": {
        "parentRunIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "consumedCommits": { "type": "array", "items": { "$ref": "#/$defs/sha" }, "uniqueItems": true }
      }
    },
    "changes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "commits"],
      "properties": {
        "files": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "commits": { "type": "array", "items": { "$ref": "#/$defs/sha" }, "uniqueItems": true }
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "status", "evidence"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed", "skipped"] },
          "evidence": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summaryPath", "logPaths"],
      "properties": {
        "summaryPath": { "type": "string", "minLength": 1 },
        "logPaths": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    },
    "integration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "conflicts"],
      "properties": {
        "status": { "enum": ["not-ready", "ready", "integrating", "integrated", "blocked", "superseded"] },
        "conflicts": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "supersededByRunId": { "type": ["string", "null"] }
      }
    }
  },
  "$defs": {
    "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
  }
}
