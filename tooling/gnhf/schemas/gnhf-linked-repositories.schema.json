{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/AgentSwitchboard/tooling/gnhf/schemas/gnhf-linked-repositories.schema.json",
  "title": "AgentSwitchboard linked repository manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "maxParallelRepos",
    "providerPreference",
    "repositories"
  ],
  "properties": {
    "schemaVersion": {
      "const": "agentswitchboard-linked-repositories/v1"
    },
    "maxParallelRepos": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "providerPreference": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "enabled",
          "repository",
          "path",
          "objectivePath",
          "agent",
          "preferredProviders",
          "preferredModels",
          "maxIterations",
          "maxTokens",
          "timeoutMinutes",
          "stopWhen",
          "dependsOn",
          "ownedScope",
          "forbiddenScope"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "enabled": {
            "type": "boolean"
          },
          "repository": {
            "type": "string",
            "pattern": "^[^/]+/[^/]+$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "objectivePath": {
            "type": "string",
            "minLength": 1
          },
          "agent": {
            "type": "string",
            "minLength": 1
          },
          "preferredProviders": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "preferredModels": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[^/]+/.+$"
            }
          },
          "maxIterations": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          },
          "maxTokens": {
            "type": "integer",
            "minimum": 1000
          },
          "timeoutMinutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1440
          },
          "stopWhen": {
            "type": "string",
            "minLength": 1
          },
          "dependsOn": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "ownedScope": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbiddenScope": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
