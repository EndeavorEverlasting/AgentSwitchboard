{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentswitchboard.local/schemas/regular-sprint-request.v1.schema.json",
  "title": "AgentSwitchboard regular sprint request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "objective",
    "repository",
    "ownedScope",
    "forbiddenScope",
    "expectedArtifacts",
    "safetyConstraints",
    "desiredProofLevel"
  ],
  "properties": {
    "kind": { "const": "regular-sprint-request" },
    "schemaVersion": { "const": 1 },
    "objective": { "type": "string", "minLength": 20 },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "remote", "localPath", "branchContext"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "remote": { "type": "string", "pattern": "^https://github\\.com/[^/]+/[^/]+(?:\\.git)?$" },
        "localPath": { "type": "string", "minLength": 3 },
        "branchContext": { "type": "string", "minLength": 1 }
      }
    },
    "ownedScope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "forbiddenScope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "expectedArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "safetyConstraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "desiredProofLevel": {
      "enum": ["contract-only", "local-workstation-observed", "committed-repository-work"]
    }
  }
}
