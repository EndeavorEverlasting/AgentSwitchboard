{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentswitchboard.local/schemas/gnhf-prompt-queue.v1.schema.json",
  "title": "AgentSwitchboard GNHF prompt queue",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "queueId",
    "maxParallel",
    "agents",
    "lanes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "agentswitchboard-gnhf-prompt-queue/v1"
    },
    "queueId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
    },
    "maxParallel": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "runtimeFamily",
          "gnhfAgent",
          "provider",
          "enabled"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{1,63}$"
          },
          "runtimeFamily": {
            "const": "Cursor"
          },
          "gnhfAgent": {
            "type": "string",
            "minLength": 1
          },
          "provider": {
            "type": [
              "string",
              "null"
            ]
          },
          "enabled": {
            "type": "boolean"
          }
        }
      }
    },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "laneId",
          "promptPath",
          "repositoryPath",
          "repositoryName",
          "repositoryRemote",
          "baseBranch",
          "pullRequestNumber",
          "dependsOn",
          "expectedArtifactPaths",
          "executionIntent",
          "desiredProofLevel",
          "timeoutSeconds"
        ],
        "properties": {
          "laneId": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{1,63}$"
          },
          "promptPath": {
            "type": "string",
            "minLength": 1
          },
          "repositoryPath": {
            "type": "string",
            "minLength": 1
          },
          "repositoryName": {
            "type": [
              "string",
              "null"
            ]
          },
          "repositoryRemote": {
            "type": [
              "string",
              "null"
            ]
          },
          "baseBranch": {
            "type": [
              "string",
              "null"
            ]
          },
          "pullRequestNumber": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "expectedArtifactPaths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^(?![A-Za-z]:|[/\\\\]).+"
            },
            "uniqueItems": true
          },
          "executionIntent": {
            "enum": [
              "local_execute",
              "registered_workflow_execute"
            ]
          },
          "desiredProofLevel": {
            "enum": [
              "local-workstation-observed",
              "committed-repository-work"
            ]
          },
          "timeoutSeconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 86400
          }
        }
      }
    }
  }
}
