{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentswitchboard.local/schemas/gnhf-prompt-queue-lane-result.v1.schema.json",
  "title": "AgentSwitchboard GNHF prompt queue lane result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "queueId",
    "laneId",
    "batchId",
    "status",
    "dependencies",
    "runtimeFamily",
    "agentProfileId",
    "gnhfAgent",
    "repoPath",
    "requestPath",
    "compiledPromptPath",
    "runtimeEvidencePath",
    "runtimeResultPath",
    "processExitCode",
    "timedOut",
    "proofLevel",
    "observedCommit",
    "observedArtifacts",
    "startedAt",
    "completedAt",
    "stdoutPath",
    "stderrPath",
    "automaticPush",
    "automaticMerge"
  ],
  "properties": {
    "schemaVersion": {
      "const": "agentswitchboard-gnhf-prompt-queue-lane-result/v1"
    },
    "queueId": {
      "type": "string",
      "minLength": 3
    },
    "laneId": {
      "type": "string",
      "minLength": 1
    },
    "batchId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "succeeded",
        "failed",
        "timed-out",
        "blocked",
        "blocked-by-dependency"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "runtimeFamily": {
      "const": "Cursor"
    },
    "agentProfileId": {
      "type": "string",
      "minLength": 1
    },
    "gnhfAgent": {
      "type": "string",
      "minLength": 1
    },
    "repoPath": {
      "type": "string",
      "minLength": 1
    },
    "requestPath": {
      "type": "string",
      "minLength": 1
    },
    "compiledPromptPath": {
      "type": "string",
      "minLength": 1
    },
    "runtimeEvidencePath": {
      "type": [
        "string",
        "null"
      ]
    },
    "runtimeResultPath": {
      "type": [
        "string",
        "null"
      ]
    },
    "processExitCode": {
      "type": [
        "integer",
        "null"
      ]
    },
    "timedOut": {
      "type": "boolean"
    },
    "proofLevel": {
      "type": "string",
      "minLength": 1
    },
    "observedCommit": {
      "type": "boolean"
    },
    "observedArtifacts": {
      "type": "boolean"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "blocker": {
      "type": [
        "string",
        "null"
      ]
    },
    "stdoutPath": {
      "type": "string",
      "minLength": 1
    },
    "stderrPath": {
      "type": "string",
      "minLength": 1
    },
    "automaticPush": {
      "const": false
    },
    "automaticMerge": {
      "const": false
    }
  }
}
