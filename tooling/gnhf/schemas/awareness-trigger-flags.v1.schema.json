{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentswitchboard.local/schemas/awareness-trigger-flags.v1.schema.json",
  "title": "Pre-analysis application flags",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "queueId", "laneId", "application", "flaggedAt", "flaggingPhase", "repositoryHead", "promptHash", "registryHash", "registeredTriggerCount", "activeTriggerCount", "criticalTriggerCount", "flags", "awarenessGate", "automaticMutation"],
  "properties": {
    "schemaVersion": { "const": "agentswitchboard-awareness-trigger-flags/v1" },
    "queueId": { "type": "string", "minLength": 3 },
    "laneId": { "type": "string", "minLength": 1 },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "repositoryName"],
      "properties": {
        "id": { "type": "string", "minLength": 2 },
        "displayName": { "type": "string", "minLength": 1 },
        "repositoryName": { "type": ["string", "null"] }
      }
    },
    "flaggedAt": { "type": "string", "format": "date-time" },
    "flaggingPhase": { "const": "pre-agent-launch" },
    "repositoryHead": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "promptHash": { "type": "string", "pattern": "^[0-9A-F]{64}$" },
    "registryHash": { "type": "string", "pattern": "^[0-9A-F]{64}$" },
    "registeredTriggerCount": { "type": "integer", "minimum": 1 },
    "activeTriggerCount": { "type": "integer", "minimum": 0 },
    "criticalTriggerCount": { "type": "integer", "minimum": 0 },
    "flags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "severity", "kind", "active", "evidence", "sourcePath"],
        "properties": {
          "id": { "type": "string", "minLength": 2 },
          "description": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["info", "warning", "critical"] },
          "kind": { "enum": ["always", "repository-path-exists", "repository-text-contains", "prompt-text-contains"] },
          "active": { "type": "boolean" },
          "evidence": { "type": "string", "minLength": 1 },
          "sourcePath": { "type": ["string", "null"] }
        }
      }
    },
    "awarenessGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "satisfied", "instruction"],
      "properties": {
        "required": { "const": true },
        "satisfied": { "const": true },
        "instruction": { "type": "string", "minLength": 20 }
      }
    },
    "automaticMutation": { "const": false }
  }
}
