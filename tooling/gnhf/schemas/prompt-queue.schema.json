{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/AgentSwitchboard/tooling/gnhf/schemas/prompt-queue.schema.json",
  "title": "GNHF Prompt Queue",
  "description": "Ordered queue of bounded GNHF prompts that compile into a deterministic multi-stage run plan.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "queueId", "generatedUtc", "sprint", "baseBranch", "lanes"],
  "properties": {
    "schema": {
      "const": "agentswitchboard.gnhf.prompt-queue.v1"
    },
    "queueId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9-]+$"
    },
    "generatedUtc": {
      "type": "string",
      "format": "date-time"
    },
    "sprint": {
      "type": "string",
      "minLength": 1
    },
    "baseBranch": {
      "type": "string",
      "minLength": 1
    },
    "targetRepository": {
      "type": "string",
      "minLength": 1
    },
    "defaultAgent": {
      "type": "string",
      "enum": ["opencode", "deepseek", "goose", "agy", "copilot", "hermes"]
    },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/promptLane" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "promptLane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "lane", "ownedScope", "forbiddenScope", "validation", "stopWhen"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9-]+$"
        },
        "lane": {
          "type": "string",
          "minLength": 1
        },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "agent": {
          "type": "string",
          "enum": ["opencode", "deepseek", "goose", "agy", "copilot", "hermes"]
        },
        "promptPath": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "maxIterations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 4
        },
        "maxTokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000000,
          "default": 250000
        },
        "ownedScope": {
          "type": "string",
          "minLength": 1
        },
        "forbiddenScope": {
          "type": "string",
          "minLength": 1
        },
        "expectedArtifacts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "validation": {
          "type": "string",
          "minLength": 1
        },
        "stopWhen": {
          "type": "string",
          "minLength": 1
        },
        "allowPush": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
