{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentswitchboard.local/schemas/compiled-gnhf-prompt-result.v1.schema.json",
  "title": "AgentSwitchboard compiled GNHF prompt result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "repository",
    "prompt",
    "gitExecution",
    "agentRoute",
    "bounds",
    "ownedScope",
    "forbiddenScope",
    "expectedArtifacts",
    "readFirst",
    "validationOrder",
    "commitContract",
    "pushContract",
    "stopCondition",
    "proofLevel",
    "proofCeiling",
    "finalResponseContract",
    "nextCommand"
  ],
  "properties": {
    "kind": { "const": "compiled-gnhf-prompt-result" },
    "schemaVersion": { "const": 1 },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "remote", "localPath"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "remote": { "type": "string", "pattern": "^https://github\\.com/[^/]+/[^/]+(?:\\.git)?$" },
        "localPath": { "type": "string", "minLength": 3 }
      }
    },
    "prompt": { "type": "string", "minLength": 100 },
    "gitExecution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "baseBranch"],
      "properties": {
        "mode": { "enum": ["worktree", "current-branch"] },
        "baseBranch": { "type": "string", "minLength": 1 }
      }
    },
    "agentRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent"],
      "properties": {
        "agent": { "type": "string", "minLength": 1 },
        "routeId": { "type": "string", "minLength": 1 }
      }
    },
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxIterations", "maxTokens", "preventSleep", "timeoutSeconds"],
      "properties": {
        "maxIterations": { "type": "integer", "minimum": 1, "maximum": 100 },
        "maxTokens": { "type": "integer", "minimum": 1, "maximum": 1000000000 },
        "preventSleep": { "type": "boolean" },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 86400 }
      }
    },
    "ownedScope": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
    "forbiddenScope": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
    "expectedArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "proof"],
        "properties": {
          "path": { "type": "string", "pattern": "^(?![A-Za-z]:|[/\\\\]).+" },
          "proof": { "type": "string", "minLength": 1 }
        }
      }
    },
    "readFirst": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
    "validationOrder": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
    "commitContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "message", "proof"],
      "properties": {
        "required": { "const": true },
        "message": { "type": "string", "minLength": 1 },
        "proof": { "type": "string", "minLength": 10 }
      }
    },
    "pushContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "merge", "deploy"],
      "properties": {
        "mode": { "enum": ["none", "manual"] },
        "merge": { "const": false },
        "deploy": { "const": false }
      }
    },
    "stopCondition": { "type": "string", "minLength": 20 },
    "proofLevel": { "enum": ["contract-only", "local-workstation-observed", "committed-repository-work"] },
    "proofCeiling": { "type": "string", "minLength": 20 },
    "finalResponseContract": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
    "nextCommand": { "type": "string", "minLength": 3 }
  },
  "$defs": {
    "nonEmptyUniqueStrings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
