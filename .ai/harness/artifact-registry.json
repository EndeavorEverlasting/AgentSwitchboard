{
  "schemaVersion": 1,
  "registryId": "agentswitchboard.repository-family-artifacts.v1",
  "artifacts": [
    {
      "artifactId": "repository-family-run-context",
      "artifactType": "run-context",
      "fileName": "run-context.json",
      "schema": ".ai/harness/schemas/run-context.schema.json",
      "tracked": false,
      "sensitivity": "local-operational",
      "retention": "operator-controlled temporary evidence",
      "proofCeiling": "read-only repository intake"
    },
    {
      "artifactId": "repository-family-status",
      "artifactType": "status-report",
      "fileName": "repository-family-status.json",
      "schema": ".ai/harness/schemas/repository-family-status.schema.json",
      "tracked": false,
      "sensitivity": "local-operational",
      "retention": "operator-controlled temporary evidence",
      "proofCeiling": "read-only repository intake"
    },
    {
      "artifactId": "repository-family-operator-report",
      "artifactType": "operator-report",
      "fileName": "operator-report.md",
      "schema": null,
      "tracked": false,
      "sensitivity": "local-operational",
      "retention": "operator-controlled temporary evidence",
      "proofCeiling": "English rendering of repository intake only"
    },
    {
      "artifactId": "repository-family-final-handoff",
      "artifactType": "final-handoff",
      "fileName": "final-handoff.json",
      "schema": ".ai/harness/schemas/final-handoff.schema.json",
      "tracked": false,
      "sensitivity": "local-operational",
      "retention": "operator-controlled temporary evidence",
      "proofCeiling": "compressed continuation record; receiving agents must re-inspect state"
    },
    {
      "artifactId": "gnhf-runtime-capability",
      "artifactType": "capability-document",
      "fileName": "gnhf-runtime-capability.json",
      "schema": ".ai/harness/schemas/gnhf-runtime-capability.schema.json",
      "tracked": false,
      "sensitivity": "local-operational",
      "retention": "fleet root under %LOCALAPPDATA%/AgentSwitchboard/GnhfFleet",
      "proofCeiling": "distribution discovery and launcher presence only; not provider delivery or deployment"
    },
    {
      "artifactId": "provider-route-install-result",
      "artifactType": "install-result",
      "fileName": "provider-route-install-result.json",
      "schema": null,
      "tracked": false,
      "sensitivity": "local-operational",
      "retention": "fleet root under %LOCALAPPDATA%/AgentSwitchboard/GnhfFleet",
      "proofCeiling": "transactional installer outcome and rollback pointer"
    },
    {
      "artifactId": "agent-startup-readiness",
      "artifactType": "status-report",
      "fileName": "agent-startup-readiness-<timestamp>.json",
      "schema": "tooling/gnhf/schemas/agent-startup-readiness.schema.json",
      "tracked": false,
      "sensitivity": "local-operational",
      "retention": "fleet reports/startup under %LOCALAPPDATA%/AgentSwitchboard/GnhfFleet",
      "proofCeiling": "local fleet-state and adapter readiness only; not provider authentication, quota, response, or delivery"
    },
    {
      "artifactId": "agent-startup-readiness-operator-report",
      "artifactType": "operator-report",
      "fileName": "agent-startup-readiness-<timestamp>.md",
      "schema": null,
      "tracked": false,
      "sensitivity": "local-operational",
      "retention": "fleet reports/startup under %LOCALAPPDATA%/AgentSwitchboard/GnhfFleet",
      "proofCeiling": "English rendering of local adapter readiness and configuration guidance only"
    }
  ]
}
