{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/AgentSwitchboard/.ai/harness/schemas/device-profile-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "registryId", "canonicalOwner", "profiles", "proofCeiling"],
  "properties": {
    "schema": {"const": "agentswitchboard.device-profile-registry.v1"},
