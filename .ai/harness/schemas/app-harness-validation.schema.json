{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/AgentSwitchboard/.ai/harness/schemas/app-harness-validation.schema.json",
  "title": "AgentSwitchboard App Harness Validation Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "generatedUtc", "repository", "runContext", "checks", "summary", "artifacts", "proofLevel", "proofCeiling"],
  "properties": {
    "schema": { "const": "agentswitchboard.app-harness-validation.v1" },
    "generatedUtc": { "type": "string", "format": "date-time" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "branch", "commit"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
      }
    },
    "runContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["networkAllowed", "runtimeAllowed", "mutationAllowed", "outputRootInsideRepository"],
      "properties": {
        "networkAllowed": { "const": false },
        "runtimeAllowed": { "const": false },
        "mutationAllowed": { "const": false },
        "outputRootInsideRepository": { "const": false }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "status", "reason", "details"],
        "properties": {
          "id": { "type": "string", "minLength": 2 },
          "name": { "type": "string", "minLength": 2 },
          "status": { "enum": ["PASS", "SKIP", "FAIL"] },
          "reason": { "type": "string" },
          "details": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "skipped", "failed"],
      "properties": {
        "passed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifactId", "path", "tracked"],
        "properties": {
          "artifactId": { "type": "string", "minLength": 2 },
          "path": { "type": "string", "minLength": 1 },
          "tracked": { "const": false }
        }
      }
    },
    "proofLevel": { "const": "offline-synthetic-harness" },
    "proofCeiling": { "type": "string", "minLength": 10 }
  }
}
