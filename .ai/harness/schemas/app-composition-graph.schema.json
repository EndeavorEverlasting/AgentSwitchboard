{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/AgentSwitchboard/.ai/harness/schemas/app-composition-graph.schema.json",
  "title": "AgentSwitchboard App Composition Graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "graphId", "observerNodeId", "nodes", "edges", "proofCeiling"],
  "properties": {
    "schema": { "const": "agentswitchboard.app-composition-graph.v1" },
    "graphId": { "type": "string", "minLength": 3 },
    "observerNodeId": { "type": "string", "minLength": 2 },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "kind", "topologyRole", "required", "paths", "safeOffline"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]+$" },
          "label": { "type": "string", "minLength": 2 },
          "kind": {
            "enum": ["request", "entrypoint", "observer", "contract", "trigger", "skill", "validator", "schema", "artifact-registry", "report-renderer", "artifact", "optional-capability"]
          },
          "topologyRole": { "enum": ["ingress", "observer", "observed", "output"] },
          "required": { "type": "boolean" },
          "paths": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "safeOffline": { "type": "boolean" },
          "description": { "type": "string" }
        }
      }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "from", "to", "event", "required"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]+$" },
          "from": { "type": "string", "minLength": 2 },
          "to": { "type": "string", "minLength": 2 },
          "event": { "type": "string", "minLength": 2 },
          "required": { "type": "boolean" },
          "description": { "type": "string" }
        }
      }
    },
    "proofCeiling": { "type": "string", "minLength": 10 }
  }
}
