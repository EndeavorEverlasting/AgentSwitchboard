{
  "schemaVersion": 1,
  "policyId": "agentswitchboard.harness-doctrine.v1",
  "canonicalSource": "AGENTS.md",
  "requiredSprintFields": ["repository", "branchOrWorktree", "prOrSprint", "lane", "ownedScope", "forbiddenScope", "expectedArtifacts", "validationOrder"],
  "executableLoop": ["request", "evidence-review", "bounded-decision", "repository-or-git-or-github-mutation", "artifacts", "validation", "report", "next-decision"],
  "actionCommitment": {
    "verbs": ["install", "set up", "build", "execute", "repair", "configure", "upgrade", "deploy", "merge", "release"],
    "requiresTrackedMutation": true,
    "requiresValidationEvidence": true,
    "requiresCommitOrGitHubEvidence": true,
    "forbidAcknowledgmentOnly": true,
    "forbidPlanSubstitution": true
  },
  "deviceProfileTaxonomy": {
    "namingConvention": "<Platform> Profile",
    "sharedLayer": "platform-neutral",
    "platformSpecificWorkMustDeclareProfile": true,
    "profileNameDoesNotProveImplementation": true,
    "reservedProfilesMayNotClaimDelivery": true,
    "profiles": [
      {"id": "windows", "displayName": "Windows Profile", "status": "current"},
      {"id": "linux", "displayName": "Linux Profile", "status": "reserved"},
      {"id": "android", "displayName": "Android Profile", "status": "reserved"}
    ]
  },
  "gnhfTestOnly": {
    "profiles": ["test", "smoke", "probe", "fixture", "contract"],
    "maxWallClockSeconds": 30,
    "maxIterationSeconds": 30,
    "defaultMaxIterations": 1,
    "requireProcessTreeTermination": true,
    "requireExplicitTimeoutEvidence": true
  },
  "deepseekUsageGate": {
    "mode": "known-nonpremium-window-only",
    "timeZone": "UTC",
    "allowedRateClasses": ["standard", "discounted"],
    "blockedRateClasses": ["double-usage", "premium-multiplier", "unknown"],
    "maximumAllowedMultiplier": 1.0,
    "defaultAction": "deny",
    "requireVerifiedSchedule": true,
    "requireSourceAndEffectiveDates": true,
    "operatorSchedulePath": "%LOCALAPPDATA%\\AgentSwitchboard\\GnhfFleet\\deepseek-usage-windows.json",
    "officialPricingReference": {
      "url": "https://api-docs.deepseek.com/quick_start/pricing/",
      "verifiedAt": "2026-07-18T00:00:00Z",
      "activeTimeOfDayWindowPublished": false,
      "historicalOffPeakWindowUtc": {"start": "16:30", "end": "00:30", "active": false, "endedAt": "2025-09-05T16:00:00Z"},
      "note": "The official API page currently publishes flat prices and no active time-of-day multiplier. Any plan-specific double-usage schedule must be supplied as a fresh operator-local schedule; unknown or stale schedule state blocks DeepSeek."
    }
  },
  "safety": {
    "evidenceBeforeConfidence": true,
    "preserveBeforeDestructiveCleanup": true,
    "reuseExistingContractsBeforeInvention": true,
    "taskSpecificRulesOverrideGenericCloseout": true,
    "noCompletionWithoutProof": true,
    "noPromptPlanOrHandoffSubstitution": true
  }
}
