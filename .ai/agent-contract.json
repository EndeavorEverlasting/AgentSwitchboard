{
  "schemaVersion": 1,
  "contractVersion": "1.4.0",
  "canonicalRepository": "EndeavorEverlasting/AgentSwitchboard",
  "canonicalRefPolicy": "merged-default-branch",
  "entrypoints": {
    "universal": "AGENTS.md",
    "claude": "CLAUDE.md",
    "skills": "SKILLS.md",
    "capabilities": "CAPABILITIES.md",
    "triggers": "TRIGGERS.md",
    "plans": "plans/plan-registry.json",
    "startupReadiness": "tooling/gnhf/Get-AgentSwitchboardStartupReport.ps1",
    "appHarness": "Test-AppHarness.cmd"
  },
  "requiredReadOrder": [
    "AGENTS.md",
    "nearest nested AGENTS.md",
    "CODEBASE_MAP.md",
    "README.md and repository operating docs",
    "tool adapter",
    "SKILLS.md",
    "CAPABILITIES.md",
    "TRIGGERS.md",
    "selected .ai/skills/*/SKILL.md",
    "plans/plan-registry.json and selected public plan",
    "docs/governance/harness-doctrine.md",
    ".ai/harness/harness-doctrine.policy.json",
    "current validators, PRs, and Git history"
  ],
  "skillRoot": ".ai/skills",
  "planRoot": "plans",
  "harnessDoctrine": {
    "policy": ".ai/harness/harness-doctrine.policy.json",
    "documentation": "docs/governance/harness-doctrine.md",
    "validator": "scripts/Test-HarnessDoctrineContract.ps1",
    "actionCommitmentRequired": true,
    "testOnlyGnhfMaxWallClockSeconds": 30,
    "testOnlyGnhfMaxIterationSeconds": 30,
    "deepSeekAllowedRateClasses": ["standard", "discounted"],
    "deepSeekDefaultAction": "deny"
  },
  "publicPlans": {
    "registry": "plans/plan-registry.json",
    "schema": "plans/schemas/public-plan.schema.json",
    "validator": "scripts/Test-PublicPlanContracts.ps1",
    "planIsNotPullRequest": true,
    "machineReadableRequired": true,
    "publicDataOnly": true
  },
  "appHarness": {
    "entrypoint": "Test-AppHarness.cmd",
    "observer": "scripts/Test-AppHarness.ps1",
    "compositionGraph": ".ai/harness/app-composition.graph.json",
    "resultSchema": ".ai/harness/schemas/app-harness-validation.schema.json",
    "reportTemplate": ".ai/harness/app-harness-report.template.md",
    "generatedOutputTracked": false,
    "proofLevel": "offline-synthetic-harness",
    "networkAllowed": false,
    "runtimeAllowed": false,
    "targetMutationAllowed": false
  },
  "startupReadiness": {
    "launcher": "AgentSwitchboard.cmd",
    "reporter": "tooling/gnhf/Get-AgentSwitchboardStartupReport.ps1",
    "schema": "tooling/gnhf/schemas/agent-startup-readiness.schema.json",
    "generatedOutputTracked": false,
    "proofLevel": "local-adapter-readiness"
  },
  "inheritance": {
    "mode": "pinned-copy-with-repository-specialization",
    "templateRoot": "templates/repository-agent-contract",
    "localRulesMayStrengthen": true,
    "localRulesMayWeaken": false,
    "propagation": "reviewable-pull-request"
  },
  "registeredRepositories": [
    {"fullName": "EndeavorEverlasting/AgentSwitchboard", "relation": "canonical-root", "status": "canonical"},
    {"fullName": "EndeavorEverlasting/Continuum", "relation": "child", "status": "registered"},
    {"fullName": "EndeavorEverlasting/foundry", "relation": "child", "status": "registered"},
    {"fullName": "EndeavorEverlasting/BlacksmithGuild", "relation": "child", "status": "registered"},
    {"fullName": "EndeavorEverlasting/SysAdminSuite", "relation": "child", "status": "registered"},
    {"fullName": "EndeavorEverlasting/web-excel-repair-triage", "relation": "child", "status": "registered"}
  ],
  "canonicalSkills": ["repo-intake", "bounded-sprint", "public-plan-coordination", "gnhf-prompt-compilation", "powershell-interactive-execution", "evidence-validation", "pr-integration", "runtime-proof"],
  "proofLevels": ["contract", "static-test", "offline-synthetic-harness", "build", "harness", "runtime", "live-target"]
}
