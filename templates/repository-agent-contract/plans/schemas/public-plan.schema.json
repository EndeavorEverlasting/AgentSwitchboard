{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/REPLACE_OWNER/REPLACE_REPOSITORY/plans/schemas/public-plan.schema.json",
  "title": "Repository Public Coordination Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "planId",
    "title",
    "repository",
    "visibility",
    "status",
    "priority",
    "createdUtc",
    "updatedUtc",
    "mission",
    "owner",
    "delivery",
    "wave",
    "lane",
    "dependencies",
    "safeParallelWork",
    "ownedScope",
    "forbiddenScope",
    "expectedArtifacts",
    "tasks",
    "validation",
    "proof",
    "handoff"
  ],
  "properties": {
    "schema": { "const": "agentswitchboard.public-plan.v1" },
    "planId": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]{4,80}$" },
    "title": { "type": "string", "minLength": 3 },
    "repository": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
    "visibility": { "const": "public" },
    "status": { "enum": ["proposed", "active", "blocked", "completed", "superseded", "rejected", "retired"] },
    "priority": { "enum": ["critical", "high", "normal", "low"] },
    "createdUtc": { "type": "string", "format": "date-time" },
    "updatedUtc": { "type": "string", "format": "date-time" },
    "mission": { "type": "string", "minLength": 10 },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "role"],
      "properties": {
        "surface": { "type": "string", "minLength": 2 },
        "role": { "type": "string", "minLength": 2 },
        "agent": { "type": ["string", "null"] }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch", "pullRequest", "baseRef", "commitRequired"],
      "properties": {
        "branch": { "type": ["string", "null"] },
        "pullRequest": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["number", "url", "state"],
              "properties": {
                "number": { "type": "integer", "minimum": 1 },
                "url": { "type": "string", "format": "uri" },
                "state": { "enum": ["draft", "open", "closed", "merged"] }
              }
            }
          ]
        },
        "baseRef": { "type": "string", "minLength": 1 },
        "commitRequired": { "type": "boolean" }
      }
    },
    "wave": { "type": "string", "minLength": 1 },
    "lane": { "type": "string", "minLength": 1 },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "safeParallelWork": { "type": "array", "items": { "type": "string" } },
    "ownedScope": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "forbiddenScope": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "expectedArtifacts": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["taskId", "title", "status", "owner", "dependencies", "inputs", "outputs", "acceptanceCriteria", "evidence"],
        "properties": {
          "taskId": { "type": "string", "pattern": "^[A-Z0-9-]{2,40}$" },
          "title": { "type": "string", "minLength": 3 },
          "status": { "enum": ["pending", "ready", "in-progress", "blocked", "completed", "skipped", "rejected"] },
          "owner": { "type": "string", "minLength": 2 },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "inputs": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "acceptanceCriteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "validation": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "achieved", "ceiling"],
      "properties": {
        "target": { "type": "string", "minLength": 2 },
        "achieved": { "type": "string", "minLength": 2 },
        "ceiling": { "type": "string", "minLength": 5 }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nextOwner", "nextCommand", "notes"],
      "properties": {
        "nextOwner": { "type": ["string", "null"] },
        "nextCommand": { "type": ["string", "null"] },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
