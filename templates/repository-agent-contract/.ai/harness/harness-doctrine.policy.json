{
  "schemaVersion": 1,
  "policyId": "agentswitchboard.harness-doctrine.v1",
  "canonicalRepository": "EndeavorEverlasting/AgentSwitchboard",
  "canonicalSource": "AGENTS.md",
  "requiredSprintFields": ["repository", "branchOrWorktree", "prOrSprint", "lane", "ownedScope", "forbiddenScope", "expectedArtifacts", "validationOrder"],
  "executableLoop": ["request", "evidence-review", "bounded-decision", "repository-or-git-or-github-mutation", "artifacts", "validation", "report", "next-decision"],
  "actionCommitment": {"requiresTrackedMutation": true, "requiresValidationEvidence": true, "requiresCommitOrGitHubEvidence": true, "forbidAcknowledgmentOnly": true, "forbidPlanSubstitution": true},
  "gnhfTestOnly": {"maxWallClockSeconds": 30, "maxIterationSeconds": 30, "defaultMaxIterations": 1, "requireProcessTreeTermination": true},
  "deepseekUsageGate": {
    "mode": "known-nonpremium-window-only",
    "allowedRateClasses": ["standard", "discounted"],
    "blockedRateClasses": ["double-usage", "premium-multiplier", "unknown"],
    "maximumAllowedMultiplier": 1.0,
    "defaultAction": "deny",
    "requireVerifiedSchedule": true,
    "operatorSchedulePath": "%LOCALAPPDATA%\\AgentSwitchboard\\GnhfFleet\\deepseek-usage-windows.json"
  },
  "runtimeEventContract": {
    "policy": ".ai/harness/runtime-event-contract.policy.json",
    "documentation": "docs/governance/runtime-event-contract.md",
    "validator": "scripts/Test-RuntimeEventContract.ps1",
    "contractOnly": true
  },
  "deviceProfileLauncherContract": {
    "policy": ".ai/harness/device-profile-launcher.policy.json",
    "documentation": "docs/governance/device-profile-launcher-contract.md",
    "validator": "scripts/Test-DeviceProfileLauncherContract.ps1",
    "canonicalOwner": "EndeavorEverlasting/AgentSwitchboard",
    "oneCanonicalLauncherPerProfile": true,
    "consumerDelegateOnly": true,
    "rawFallbackForbidden": true,
    "separatePlatformImplementations": true,
    "contractOnly": true
  },
  "localRulesMayStrengthen": true,
  "localRulesMayWeaken": false
}
